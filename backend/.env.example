# =============================================================================
# Tele ROSE — backend env vars
#
# Copie este arquivo para `.env.local` (gitignored) e preencha com as credenciais
# reais do seu projeto Supabase. NUNCA commite o .env.local.
# =============================================================================

# Postgres (Supabase). Use o "Connection pooling" (pgBouncer/Supavisor) na porta
# 6543 com `?pgbouncer=true&connection_limit=1` para serverless,
# ou a Direct Connection (porta 5432) para o backend NestJS de longa vida.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Supabase project — usados pelo backend para verificar JWT e chamar Admin API
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # NUNCA exponha no cliente — só backend
SUPABASE_JWT_SECRET="..."

# LiveKit (streaming ao vivo)
LIVEKIT_URL="wss://..."
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# NTP — servidor oficial do Observatório Nacional
NTP_HOST="a.ntp.br"

# Aplicação
NODE_ENV="development"
PORT="3000"
LOG_LEVEL="debug"
